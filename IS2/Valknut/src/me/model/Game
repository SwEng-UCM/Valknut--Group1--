package me.model

public class Game(){

    private Controller ctrl;
    private List<Player> player = new ArrayList<>(4);
    private Combat combat;

    public Game(Controller ctrl){
        this.ctrl = ctrl;
    }

    public void initializeCombat(){
        combat = new Combat();
    }

    public void addHero(Hero e){
        player.add(e);
    }

}